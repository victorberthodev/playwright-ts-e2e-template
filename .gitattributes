# Normalize all text files to LF on commit. Prevents Windows autocrlf
# from re-marking files as modified on each clone/checkout. Matches the
# .editorconfig setting (`end_of_line = lf`) and the Prettier config.

* text=auto eol=lf

# Explicit LF for text formats we care about.
*.ts        text eol=lf
*.js        text eol=lf
*.json      text eol=lf
*.md        text eol=lf
*.yml       text eol=lf
*.yaml      text eol=lf
*.env       text eol=lf
*.example   text eol=lf
*.editorconfig text eol=lf
*.gitignore text eol=lf
*.prettierrc text eol=lf

# Binary blobs — never normalize.
*.png       binary
*.jpg       binary
*.gif       binary
*.ico       binary
*.zip       binary
*.pdf       binary
