# Shared defaults across all environments. Per-env overrides go in
# .env.dev / .env.stg / .env.prd.
#
# Copy to `.env` and adjust. Never commit real secrets.

# Active environment. One of: dev | stg | prd. Defaults to dev.
TEST_ENV=dev

# SauceDemo credentials (these are the documented public values — fine to
# leave as-is for the dev environment).
STANDARD_USER=standard_user
STANDARD_PASSWORD=secret_sauce
LOCKED_USER=locked_out_user
PROBLEM_USER=problem_user
PERFORMANCE_USER=performance_glitch_user
